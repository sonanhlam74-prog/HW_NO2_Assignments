@model Exer3App.Models.Book
@{
    ViewData["Title"] = "Create Book";
}

<h2>Thêm sách</h2>

@if (TempData["SuccessMessage"] is not null)
{
    <div class="alert alert-success">@TempData["SuccessMessage"]</div>
}

<form asp-action="Create" asp-controller="Book" method="post" class="mt-3">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <div class="mb-3">
        <label asp-for="Name" class="form-label"></label>
        <input asp-for="Name" class="form-control" />
        <span asp-validation-for="Name" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Price" class="form-label"></label>
        <input asp-for="Price" class="form-control" />
        <span asp-validation-for="Price" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-primary">Lưu</button>
    <a asp-controller="Book" asp-action="Index" class="btn btn-secondary">Danh sách</a>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
