@page
@model New_folder.Pages.Books.DetailsModel
@{
    ViewData["Title"] = "Book Details";
}

<h1>Book Details</h1>

<dl class="row">
    <dt class="col-sm-2">Id</dt>
    <dd class="col-sm-10">@Model.Book?.Id</dd>

    <dt class="col-sm-2">Title</dt>
    <dd class="col-sm-10">@Model.Book?.Title</dd>

    <dt class="col-sm-2">Author</dt>
    <dd class="col-sm-10">@Model.Book?.Author</dd>

    <dt class="col-sm-2">Year</dt>
    <dd class="col-sm-10">@Model.Book?.Year</dd>

    <dt class="col-sm-2">Description</dt>
    <dd class="col-sm-10">@Model.Book?.Description</dd>
</dl>

<a asp-page="Index" class="btn btn-secondary">Back to list</a>
<a asp-page="Edit" asp-route-id="@Model.Book?.Id" class="btn btn-primary">Edit</a>
