@page
@model New_folder.Pages.Books.DeleteModel
@{
    ViewData["Title"] = "Delete Book";
}

<h1>Delete Book</h1>

@if (Model.Book == null)
{
    <div class="alert alert-warning">Book not found.</div>
}
else
{
    <div class="alert alert-danger">
        <strong>Confirm delete this book?</strong>
    </div>
    <dl class="row">
        <dt class="col-sm-2">Title</dt>
        <dd class="col-sm-10">@Model.Book.Title</dd>
        <dt class="col-sm-2">Author</dt>
        <dd class="col-sm-10">@Model.Book.Author</dd>
        <dt class="col-sm-2">Year</dt>
        <dd class="col-sm-10">@Model.Book.Year</dd>
        <dt class="col-sm-2">Description</dt>
        <dd class="col-sm-10">@Model.Book.Description</dd>
    </dl>

    <form method="post">
        <button type="submit" class="btn btn-danger">Delete</button>
        <a asp-page="Index" class="btn btn-secondary">Cancel</a>
    </form>
}
